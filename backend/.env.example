# ================================================
# AUTONOMOUS JOB APPLICATION AGENT - ENVIRONMENT
# ================================================

# --------------------------------------------
# NVIDIA NIM API (FREE - https://build.nvidia.com)
# Supports 40 requests/second on free tier
# Model: meta/llama-3.1-70b-instruct
# --------------------------------------------
NVIDIA_API_KEY=your_nvidia_api_key_here

# --------------------------------------------
# GOOGLE SHEETS DATABASE
# 1. Go to https://console.cloud.google.com
# 2. Create Service Account, download JSON credentials
# 3. Share your Google Sheet with the service account email
# --------------------------------------------
GOOGLE_CREDENTIALS_FILE=credentials.json
# OR store as JSON string:
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}
GOOGLE_SHEETS_ID=your_google_sheets_spreadsheet_id_here

# --------------------------------------------
# EMAIL (Gmail SMTP)
# 1. Enable 2FA on your Gmail account
# 2. Go to: Google Account > Security > App passwords
# 3. Generate an App Password for "Mail"
# --------------------------------------------
EMAIL_SENDER=yourname@gmail.com
EMAIL_APP_PASSWORD=your_gmail_app_password_16chars

# --------------------------------------------
# OPTIONAL: OpenAI fallback
# --------------------------------------------
# OPENAI_API_KEY=sk-...

# --------------------------------------------
# FLASK
# --------------------------------------------
FLASK_ENV=development
FLASK_DEBUG=1
PORT=5000
